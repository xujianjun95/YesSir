{
    "manifest_version": 3,
    "name": "__MSG_extensionName__",
    "version": "1.5",
    "description": "__MSG_extensionDescription__",
    "default_locale": "zh_CN",
    "permissions": [
      "tabs",
      "storage",
      "sessions",
      "tabGroups",
      "windows",
      "favicon",
      "search"
    ],
    "host_permissions": [
      "https://api.deepseek.com/*",
      "https://api.pmtools.com.cn/*",
      "https://suggestqueries.google.com/*"
    ],
    "web_accessible_resources": [
      {
        "resources": ["_favicon/*"],
        "matches": ["<all_urls>"]
      }
    ],
    "icons": {
      "16":  "icon_16.png",
      "48":  "icon_48.png",
      "128": "icon_128.png"
    },
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": [
          "content.js",
          "content-switcher/01-utils-and-state.js",
          "content-switcher/02-selection-and-scroll.js",
          "content-switcher/03-build-tab-item.js",
          "content-switcher/04b-switcher-list-bundle.js",
          "content-switcher/04-show-switcher.js",
          "content-switcher/05-hide-and-toasts.js"
        ]
      }
    ]
  }
