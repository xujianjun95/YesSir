{
    "manifest_version": 3,
    "name": "AI自动分组 | 跨窗口标签页管理 | 快速切换 | 双击关闭 | 智能搜索 | 毛玻璃风格 - YesSir",
    "version": "1.4",
    "description": "支持你在按住 Command(Mac)/Alt(Win) 的时候双击网页空白处来关闭当前标签页，或滚动鼠标滚轮来切换标签页",
    "permissions": [
      "tabs",
      "storage",
      "sessions",
      "tabGroups",
      "windows"
    ],
    "host_permissions": [
      "https://api.deepseek.com/*",
      "https://api.pmtools.com.cn/*"
    ],
    "icons": {
      "16":  "icon_16.png",
      "48":  "icon_48.png",
      "128": "icon_128.png"
    },
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js", "content-switcher.js"]
      }
    ]
  }
